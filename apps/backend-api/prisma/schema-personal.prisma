// AusDrive Fleet Manager - Personal System Schema
// Single company, no multi-tenant complexity

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [postgis]
}

// ============================================
// ENUMS
// ============================================

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum CarStatus {
  AVAILABLE
  BOOKED
  RENTED
  MAINTENANCE
  OUT_OF_SERVICE
}

enum RentalStatus {
  BOOKED
  ACTIVE
  RETURNED
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  OTHER
}

enum MaintenanceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MaintenanceType {
  ROUTINE_SERVICE
  TYRE_REPLACEMENT
  BRAKE_SERVICE
  ENGINE_REPAIR
  BODY_REPAIR
  ELECTRICAL
  AC_SERVICE
  TRANSMISSION
  OIL_CHANGE
  BATTERY
  BELT
  OTHER
}

enum DocumentType {
  REGISTRATION
  INSURANCE
  ROADWORTHY
  MAINTENANCE_INVOICE
  OTHER
}

enum NotificationType {
  RENTAL_DUE_TODAY
  RENTAL_OVERDUE
  PAYMENT_PENDING
  MAINTENANCE_DUE
  INSURANCE_EXPIRY
  REGISTRATION_EXPIRY
  SERVICE_DUE
}

// ============================================
// AUTHENTICATION
// ============================================

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  passwordHash  String
  firstName     String
  lastName      String
  phone         String?
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ============================================
// FLEET MANAGEMENT
// ============================================

model Car {
  id                  String              @id @default(cuid())
  registrationNumber  String              @unique
  vin                 String?             @unique
  make                String
  model               String
  year                Int
  color               String?
  category            String              // Sedan, SUV, Van, etc.
  dailyRateCents      Int
  odometerKm          Int                 @default(0)
  fuelType            String?             // Petrol, Diesel, Electric
  transmission        String?             // Manual, Automatic
  seats               Int?
  status              CarStatus           @default(AVAILABLE)
  location            String?             // Current location/branch
  trackerInstalled    Boolean             @default(false)
  nextServiceDue      DateTime?
  nextServiceKm       Int?
  insuranceExpiry     DateTime?
  registrationExpiry  DateTime?
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  images              CarImage[]
  documents           CarDocument[]
  rentals             Rental[]
  maintenanceJobs     MaintenanceJob[]
  gpsDevice           GpsDevice?
  
  @@index([status])
  @@index([registrationNumber])
}

model CarImage {
  id         String   @id @default(cuid())
  carId      String
  imageUrl   String
  isPrimary  Boolean  @default(false)
  uploadedAt DateTime @default(now())
  car        Car      @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
}

model CarDocument {
  id            String       @id @default(cuid())
  carId         String
  type          DocumentType
  name          String
  fileUrl       String
  fileSizeBytes Int          @default(0)
  mimeType      String?
  expiresAt     DateTime?
  uploadedAt    DateTime     @default(now())
  car           Car          @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@index([carId])
  @@index([expiresAt])
}

// ============================================
// CUSTOMERS
// ============================================

model Customer {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String
  address       String?
  licenseNumber String   @unique
  licenseExpiry DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  rentals       Rental[]
  payments      Payment[]

  @@index([licenseNumber])
  @@index([phone])
}

// ============================================
// RENTALS
// ============================================

model Rental {
  id                   String            @id @default(cuid())
  carId                String
  customerId           String
  pickupAt             DateTime
  expectedReturnAt     DateTime
  actualReturnAt       DateTime?
  startOdometerKm      Int
  endOdometerKm        Int?
  dailyRateCents       Int
  totalDays            Int
  subtotalCents        Int
  discountCents        Int               @default(0)
  depositCents         Int               @default(0)
  lateFeesCents        Int               @default(0)
  damageChargesCents   Int               @default(0)
  fuelPenaltyCents     Int               @default(0)
  totalAmountCents     Int
  paidAmountCents      Int               @default(0)
  balanceDueCents      Int
  status               RentalStatus      @default(BOOKED)
  fuelLevelAtPickup    String?           // Full, 3/4, Half, 1/4, Empty
  fuelLevelAtReturn    String?
  notes                String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  car                  Car               @relation(fields: [carId], references: [id], onDelete: Restrict)
  customer             Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  extensions           RentalExtension[]
  payments             Payment[]

  @@index([carId])
  @@index([customerId])
  @@index([status])
  @@index([expectedReturnAt])
}

model RentalExtension {
  id                    String   @id @default(cuid())
  rentalId              String
  previousReturnAt      DateTime
  newReturnAt           DateTime
  additionalDays        Int
  additionalAmountCents Int
  notes                 String?
  createdAt             DateTime @default(now())
  rental                Rental   @relation(fields: [rentalId], references: [id], onDelete: Cascade)

  @@index([rentalId])
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id              String        @id @default(cuid())
  rentalId        String?
  customerId      String?
  amountCents     Int
  method          PaymentMethod
  status          PaymentStatus @default(PAID)
  reference       String?
  receiptUrl      String?       // PDF receipt URL
  notes           String?
  paidAt          DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  rental          Rental?       @relation(fields: [rentalId], references: [id], onDelete: SetNull)
  customer        Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)

  @@index([rentalId])
  @@index([customerId])
  @@index([status])
  @@index([paidAt])
}

// ============================================
// MAINTENANCE
// ============================================

model MaintenanceJob {
  id              String            @id @default(cuid())
  carId           String
  type            MaintenanceType
  status          MaintenanceStatus @default(PENDING)
  description     String?
  workshopName    String?
  estimatedCostCents Int?
  finalCostCents  Int?
  odometerKm      Int?
  scheduledAt     DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  nextServiceDue  DateTime?
  nextServiceKm   Int?
  invoiceUrl      String?           // PDF invoice URL
  notes           String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  car             Car               @relation(fields: [carId], references: [id], onDelete: Cascade)
  parts           MaintenancePart[]

  @@index([carId])
  @@index([status])
  @@index([scheduledAt])
}

model MaintenancePart {
  id              String         @id @default(cuid())
  maintenanceId   String
  partName        String
  partNumber      String?
  quantity        Int            @default(1)
  costCents       Int
  supplier        String?
  createdAt       DateTime       @default(now())
  maintenance     MaintenanceJob @relation(fields: [maintenanceId], references: [id], onDelete: Cascade)

  @@index([maintenanceId])
}

// ============================================
// GPS TRACKING (PostGIS)
// ============================================

model GpsDevice {
  id              String            @id @default(cuid())
  carId           String            @unique
  imei            String            @unique
  simNumber       String?
  provider        String?
  secretKey       String?           // For secure GPS data push
  isActive        Boolean           @default(true)
  lastPingAt      DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  car             Car               @relation(fields: [carId], references: [id], onDelete: Cascade)
  trackingLogs    GpsTrackingLog[]
  liveStatus      GpsLiveStatus?

  @@index([imei])
  @@index([carId])
}

model GpsTrackingLog {
  id               String     @id @default(cuid())
  deviceId         String
  location         Unsupported("geography(Point, 4326)")
  lat              Float
  lng              Float
  speedKmh         Float?
  heading          Float?
  altitude         Float?
  ignitionOn       Boolean    @default(false)
  batteryVoltage   Float?
  fuelLevelPercent Float?
  recordedAt       DateTime
  createdAt        DateTime   @default(now())
  device           GpsDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId, recordedAt])
  @@index([recordedAt])
}

model GpsLiveStatus {
  id               String     @id @default(cuid())
  deviceId         String     @unique
  location         Unsupported("geography(Point, 4326)")
  lat              Float
  lng              Float
  speedKmh         Float?
  heading          Float?
  altitude         Float?
  ignitionOn       Boolean    @default(false)
  batteryVoltage   Float?
  fuelLevelPercent Float?
  recordedAt       DateTime
  updatedAt        DateTime   @updatedAt
  device           GpsDevice  @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  entityType  String?          // car, rental, payment, maintenance
  entityId    String?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([isRead, createdAt])
  @@index([entityType, entityId])
}
